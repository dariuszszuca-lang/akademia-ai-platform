# Hasło dostępu do panelu administracyjnego (/admin).
# Wymagane. Ustaw to samo w Vercel → Settings → Environment Variables.
ADMIN_PASSWORD=zmien-to-haslo

# Opcjonalnie: własny sekret do podpisywania cookie. Jeśli pusty, używane jest ADMIN_PASSWORD.
# ADMIN_SESSION_SECRET=losowy-ciag-znakow

# Vercel KV — zmienne wygenerowane automatycznie po włączeniu KV w Vercel dashboard:
# Storage → Create Database → KV → Connect to Project.
# Jeśli KV nie jest skonfigurowane, platforma działa z domyślnymi flagami z src/data/modules.ts.
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...
# KV_REST_API_READ_ONLY_TOKEN=...
# KV_URL=redis://...
